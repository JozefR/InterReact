{
  "Runtime": {
    "Environment": "Development",
    "LogLevel": "Information"
  },
  "DataIngestion": {
    "Provider": "Mock",
    "Universes": [
      "SP500",
      "SP100"
    ],
    "EnableDailyRefresh": true,
    "RequestTimeoutSeconds": 30,
    "MassiveApiBaseUrl": "https://api.massive.com",
    "MassiveUseFixtureFallbackWhenApiKeyMissing": true
  },
  "DataWarehouse": {
    "ConnectionString": "Server=localhost;Database=ResearchPlatform;Trusted_Connection=True;TrustServerCertificate=True;",
    "MaxBatchSize": 1000
  },
  "Backtest": {
    "InitialCapital": 50000,
    "CommissionBps": 1.0,
    "SlippageBps": 2.0
  }
}
